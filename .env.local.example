# =============================================================================
# Policy Canary — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# =============================================================================

# Supabase (Required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# LLM — Multi-provider via Vercel AI SDK (Required for pipeline + AI features)
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_key      # Data processing / enrichment
OPENAI_API_KEY=your_openai_key                     # Embeddings (text-embedding-3-small)
ANTHROPIC_API_KEY=your_anthropic_key               # Email writing / AI search

# Payments (Required for subscriptions)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Email (Required for digest delivery)
RESEND_API_KEY=re_your_resend_api_key

# Inngest (Background jobs / pipeline orchestration)
INNGEST_SIGNING_KEY=signkey-prod-your_inngest_signing_key
INNGEST_EVENT_KEY=your_inngest_event_key

# Analytics (Optional)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
